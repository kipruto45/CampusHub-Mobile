# API Configuration for CampusHub Mobile App
# Use 10.0.2.2 for Android Emulator (accesses host machine's localhost)
# Use localhost or 127.0.0.1 for iOS Simulator
# Use your local IP address for physical devices

# For physical Android/iOS device on same Wi-Fi as backend machine:
EXPO_PUBLIC_API_URL=http://192.168.0.106:8000/api

# For iOS Simulator (uncomment below and comment above):
# EXPO_PUBLIC_API_URL=http://localhost:8000

# For Android Emulator (uncomment below when using emulator):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api
